<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>CmnFlix - Login</title> 
        <link rel="icon" type="image/png" sizes="32x32" href="/Home/favicon-32x32.png">
    <link rel="icon" href="/Home/favicon.ico" type="image/x-icon">
        <link rel="stylesheet" href="/bootstrap-5.0.2-dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="/fontawesome-free-6.4.2-web/css/all.min.css">
        <link rel="stylesheet" href="/style.css">
        <link rel="stylesheet" href="movies.css">
    </head>
    <body>
    <div class="register-container">
        <div class="register">
            <form action="/login" method="POST">
                <h1>Login</h1>

                <!-- Sign-up Information Section -->
                <label for="email">Email:</label>
                <input type="email" name="email" required>
                      
                <label for="password">Password:</label>
                <input type="password" name="password" required>
                 
                <button type="submit">Login</button>
                <div class="links">
                    <p class="phrase">Don't have an account? <a href="/register">Register</a></p>
                    <p><a href="/forgot-password">Forgot Password</a></p>
                </div>
                <% if (error) { %>
                    <div style="color: red; text-align: center; font-size: 14px; margin-top: 6px;"><%= error %></div>
                <% } %> 
            </form>
        
            <div class="sign">
                <h1>Login</h1>
                <p>Don't have an account? <a href="/register">Register</a></p>
            </div>
        </div>
    </div>
</body>
</html>