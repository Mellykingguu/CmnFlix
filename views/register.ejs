<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Cmn - Register</title> 
        <link rel="icon" type="image/png" sizes="32x32" href="/Home/favicon-32x32.png">
    <link rel="icon" href="/Home/favicon.ico" type="image/x-icon">
        <link rel="stylesheet" href="/bootstrap-5.0.2-dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="/fontawesome-free-6.4.2-web/css/all.min.css">
        <link rel="stylesheet" href="/style.css">
        <link rel="stylesheet" href="movies.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/css/intlTelInput.css" />
      </head>
<body>
    <div class="register-container">
        <div class="register">
            <form action="/register" method="POST">
                <h1>Register</h1>

                <label for="name"> First Name:</label>
                <input type="text" name="firstname" required>
                        
                <label for="name"> Last Name:</label>
                <input type="text" name="lastname" required>                        
                        
                <label for="email">Email:</label>
                <input type="email" name="email" required>
                        
                <div style="display: flex; justify-content: space-between; width: 100%;">
                    <div style="display: flex; flex-direction: column; margin-top: 4px; width: 48%;">
                        <label for="phone-number">Phone Number:</label>
                        <input type="tel" id="phone" name="number" required>
                    </div> 
                    <div style="display: flex; flex-direction: column; margin-top: 4px; width: 48%;">
                        <label for="age">Age:</label>
                        <input type="number" id="age" name="age" required>
                    </div> 
                </div>  
                
                <label for="referralcode">Referral code(Optional):</label>
                <input type="text" name="referralcode" id="referralcode">
                      
                <label for="password">Password:</label>
                <input type="password" name="password" required>
                      
                <label for="confirm-password">Confirm Password:</label>
                <input type="password" name="repassword" required>
                
                <button type="submit">Register</button>
                <p>Already have an account? <a href="/login">Login</a></p>
                <% if (error) { %>
                    <div style="color: red; text-align: center; font-size: 14px; margin-top: 6px;"><%= error %></div>
                <% } %> 
            </form>
        
            <div class="sign">
                <h1>Register</h1>
                <p>Already have an account? <a href="/login">Login</a></p>
            </div>
        </div>
    </div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/intlTelInput.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const phoneInput = document.getElementById('phone');
        const iti = window.intlTelInput(phoneInput, {
            initialCountry: "CM", // Set initial country to Cameroon
            separateDialCode: true, // Show dial code separately
            onlyCountries: ["CM"], // Limit to only Cameroon
            utilsScript: "https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/lib/libphonenumber.js" // Include utils script
        });

        // Optional: Log the selected country code and phone number
        phoneInput.addEventListener('input', () => {
            const dialCode = iti.getSelectedCountryData().dialCode;
            const phoneNumber = phoneInput.value.replace(dialCode, '');           
        });
    });
</script>
</body>
</html>